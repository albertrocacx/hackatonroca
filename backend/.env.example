# Plantilla de variables para /search semántico (Azure). Copia a `.env` y rellena.
#   cp .env.example .env    (o copia manual en Windows)
# El `.env` real NO se sube al repo; este `.env.example` sí (sin secretos).

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<tu-servicio>.search.windows.net
AZURE_SEARCH_KEY=<query-o-admin-key>
AZURE_SEARCH_INDEX=rag-test4

# Azure OpenAI (embeddings)
AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.services.ai.azure.com
AZURE_OPENAI_KEY=<api-key>
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_EMBED_DEPLOYMENT=text-embedding-3-large-2
AZURE_EMBED_DIMENSIONS=3072
AZURE_VECTOR_FIELD=text_vector

# Nº de vecinos a pedir a Azure (recall para las facetas)
AZURE_SEARCH_K=120
