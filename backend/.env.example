# Plantilla de variables para /search semántico (Azure). Copia a `.env` y rellena.
#   cp .env.example .env    (o copia manual en Windows)
# El `.env` real NO se sube al repo; este `.env.example` sí (sin secretos).

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<tu-servicio>.search.windows.net
AZURE_SEARCH_KEY=<query-o-admin-key>
AZURE_SEARCH_INDEX=rag-test4

# Azure OpenAI (embeddings)
AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.services.ai.azure.com
AZURE_OPENAI_KEY=<api-key>
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_EMBED_DEPLOYMENT=text-embedding-3-large-2
AZURE_EMBED_DIMENSIONS=3072
AZURE_VECTOR_FIELD=text_vector

# OCR de PDFs desde Blob Storage (ocr_pdf_blob.py) — LLM de Azure AI Foundry (cliente OpenAI v1).
FOUNDRY_ENDPOINT=https://aihackathonfoundry.services.ai.azure.com/openai/v1
FOUNDRY_API_KEY=<api-key-de-foundry>
FOUNDRY_DEPLOYMENT=gpt-5.4-nano
AZURE_STORAGE_CONNECTION_STRING=<connection-string-de-la-cuenta>
OCR_SOURCE_CONTAINER=data
OCR_SOURCE_PREFIX=
# El .md se sube al mismo contenedor y carpeta que el PDF de origen (misma ruta, .pdf -> .md).
# Indexación en Azure AI Search (index_ocr_aisearch.py): usa AZURE_SEARCH_* y AZURE_EMBED_* de arriba.
OCR_INDEX_NAME=ocr-catalogos

# Nº de vecinos a pedir a Azure (recall para las facetas)
AZURE_SEARCH_K=120
